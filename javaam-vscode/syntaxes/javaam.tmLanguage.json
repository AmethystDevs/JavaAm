{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JavaAm",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#block_markers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.javaam",
          "begin": "//",
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.javaam",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.javaam",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.javaam",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.javaam",
          "match": "\\b(class|package|return|new|block|item|register|group|type|properties|function|math|var|solve|print|modReg|MOD_ID|LOGGER|regLog|in)\\b"
        }
      ]
    },
    "block_markers": {
      "patterns": [
        {
          "name": "punctuation.definition.block.javaam",
          "match": "\\|-|-\\|"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.javaam",
          "match": "(\\+|-|\\*|/|%|==|!=|<=|>=|<|>|=|\\.)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.class.javaam",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        },
        {
          "name": "variable.other.javaam",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "scopeName": "source.javaam"
}
